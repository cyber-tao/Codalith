{
  "corpora": {
    "${CODALITH_SAMPLE_CORPUS_ID:-sample-codebase}": {
      "kind": "source",
      "version": "${CODALITH_SAMPLE_VERSION:-sample}",
      "display_name": "${CODALITH_SAMPLE_DISPLAY_NAME:-Sample Codebase}",
      "description": "${CODALITH_SAMPLE_DESCRIPTION:-Small neutral source corpus for local Codalith development}",
      "keywords": [
        "source code",
        "API",
        "architecture",
        "cache",
        "events"
      ],
      "source_revision": "${CODALITH_SAMPLE_SOURCE_REVISION:-sample-v1}",
      "source_root": "${CODALITH_SAMPLE_SOURCE_ROOT:-fixtures/sample_corpus}",
      "indexed_root": "${CODALITH_SAMPLE_INDEXED_ROOT:-fixtures/sample_corpus}",
      "coderag_store": "${CODALITH_SAMPLE_CODERAG_STORE_DIR:-data/coderag/sample-codebase}",
      "semantic_schema": "${CODALITH_SAMPLE_SEMANTIC_SCHEMA:-sample_codebase}",
      "card_root": "${CODALITH_SAMPLE_CARD_ROOT:-data/cards/sample-codebase}",
      "seed_cards_path": "${CODALITH_SAMPLE_SEED_CARDS:-configs/sample/seed_cards.json}",
      "source_priors_path": "${CODALITH_SAMPLE_SOURCE_PRIORS:-configs/sample/source_priors.json}",
      "default": true,
      "access_scopes": ["source:read"],
      "scope_prefixes": {
        "source": ["src/"],
        "docs": ["docs/"]
      },
      "module_roots": ["src"],
      "index_ignore_dirs": [".venv", "node_modules", "dist", "build", "__pycache__", "cards"],
      "index_suffixes": [".py", ".md", ".json", ".toml", ".yaml", ".yml"]
    }
  },
  "projects": {},
  "generated": {}
}

{
  "engines": {
    "ue-${CODALITH_ENGINE_VERSION:-5.7.4}": {
      "kind": "engine",
      "version": "${CODALITH_ENGINE_VERSION:-5.7.4}",
      "display_name": "${CODALITH_ENGINE_DISPLAY_NAME:-Unreal Engine}",
      "description": "${CODALITH_ENGINE_DESCRIPTION:-Unreal Engine full source tree (C++, Build.cs, plugins, generated reflection code)}",
      "keywords": [
        "Unreal Engine",
        "UE5",
        "UHT",
        "reflection",
        "Build.cs",
        "networking",
        "rendering",
        "gameplay framework",
        "editor",
        "asset",
        "GC",
        "serialization"
      ],
      "source_commit": "${CODALITH_ENGINE_SOURCE_COMMIT:-UNKNOWN}",
      "source_root": "${CODALITH_ENGINE_SOURCE_ROOT:-/srv/ue/5.7.4}",
      "indexed_root": "${CODALITH_ENGINE_INDEXED_ROOT:-/srv/codalith/corpora/ue-5.7.4}",
      "coderag_store": "${CODALITH_CODERAG_STORE_DIR:-/var/lib/codalith/coderag/ue-5.7.4}",
      "semantic_schema": "${CODALITH_ENGINE_SEMANTIC_SCHEMA:-ue_5_7_4}",
      "card_root": "${CODALITH_ENGINE_CARD_ROOT:-/srv/codalith/cards/ue-5.7.4}",
      "default": true,
      "access_scopes": ["${CODALITH_ENGINE_ACCESS_SCOPE:-ue:5.7}", "source:read"]
    }
  },
  "projects": {
    "${CODALITH_PROJECT_ID:-ProjectA}": {
      "kind": "project",
      "display_name": "${CODALITH_PROJECT_DISPLAY_NAME:-Game project overlay}",
      "engine_corpus": "ue-${CODALITH_ENGINE_VERSION:-5.7.4}",
      "source_root": "${CODALITH_PROJECT_SOURCE_ROOT:-fixtures/project_overlay/ProjectA}",
      "indexed_root": "${CODALITH_PROJECT_INDEXED_ROOT:-fixtures/project_overlay/ProjectA}",
      "coderag_store": "${CODALITH_PROJECT_CODERAG_STORE_DIR:-data/coderag/project-a}",
      "semantic_schema": "${CODALITH_PROJECT_SEMANTIC_SCHEMA:-project_a}",
      "card_root": "${CODALITH_PROJECT_CARD_ROOT:-data/cards/project-a}",
      "access_scopes": ["${CODALITH_PROJECT_ACCESS_SCOPE:-project:ProjectA}", "source:read"]
    }
  },
  "generated": {
    "generated-ue-${CODALITH_ENGINE_VERSION:-5.7.4}": {
      "kind": "generated",
      "engine_corpus": "ue-${CODALITH_ENGINE_VERSION:-5.7.4}",
      "version": "${CODALITH_ENGINE_VERSION:-5.7.4}",
      "source_root": "${CODALITH_GENERATED_SOURCE_ROOT:-data/generated/ue-5.7.4}",
      "indexed_root": "${CODALITH_GENERATED_INDEXED_ROOT:-data/generated/ue-5.7.4}",
      "coderag_store": "${CODALITH_GENERATED_CODERAG_STORE_DIR:-data/coderag/generated-ue-5.7.4}",
      "semantic_schema": "${CODALITH_GENERATED_SEMANTIC_SCHEMA:-generated_ue_5_7_4}",
      "card_root": "${CODALITH_GENERATED_CARD_ROOT:-data/cards/generated-ue-5.7.4}",
      "access_scopes": ["${CODALITH_GENERATED_ACCESS_SCOPE:-generated:read}", "source:read"]
    }
  }
}

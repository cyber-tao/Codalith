# UE 5.7.4 product corpus — append to .env when using the UE profile.
# Replace host paths and credentials locally; never commit .env or mounted assets.

CODALITH_UE_VERSION=5.7.4
CODALITH_UE_SOURCE_REVISION=5.7.4
CODALITH_UE_DISPLAY_NAME=UE 5.7 Source Corpus
CODALITH_UE_DESCRIPTION=Full Unreal Engine 5.7.4 source corpus backed by the local CodeRAG embedding store
CODALITH_UE_CORPUS_REGISTRY=configs/corpora/ue-5.7.4/registry.json

# Host paths (Compose bind mounts). Use relative repo paths or absolute host paths.
CODALITH_UE_HOST_ROOT=./.local/ue-5.7.4
CODALITH_UE_SOURCE_HOST_ROOT=./.local/ue-5.7.4/Engine/Source
CODALITH_UE_PLUGINS_HOST_ROOT=./.local/ue-5.7.4/Engine/Plugins
CODALITH_UE_CODERAG_HOST_DIR=./.local/coderag-openai-store/ue-5.7.4-openai-qwen3-embedding-8b-3072c-3584b-full

# Container paths used inside Compose services.
CODALITH_UE_SOURCE_ROOT=/srv/ue/5.7.4
CODALITH_UE_INDEXED_ROOT=/srv/codalith/corpora/ue-5.7.4
CODALITH_UE_CODERAG_STORE_DIR=/var/lib/codalith/coderag/ue-5.7.4
CODALITH_UE_CARD_ROOT=data/cards/ue-5.7.4
CODALITH_UE_SEMANTIC_SCHEMA=ue_5_7_4
CODALITH_UE_SOURCE_PRIORS=configs/corpora/ue-5.7.4/source_priors.json
CODALITH_UE_SEED_CARDS=configs/corpora/ue-5.7.4/seed_cards.json
CODALITH_UE_STORE_MANIFEST=configs/corpora/ue-5.7.4/store_manifest.json

# Native CodeRAG (strict — no local fallback for product acceptance).
CODALITH_USE_NATIVE_CODERAG=1
CODALITH_NATIVE_CODERAG_STRICT=1
CODALITH_CODERAG_PROVIDER=openai
CODALITH_CODERAG_EMBEDDING_MODEL=Qwen3-Embedding-8B
CODALITH_CODERAG_EMBEDDING_BATCH_SIZE=32
CODALITH_CODERAG_WORKERS=4
OPENAI_BASE_URL=https://api.example.com/v1
OPENAI_API_KEY=replace-me

# Codalith local/deployment configuration.
# Copy this file to .env and change paths/credentials per machine.

# Default neutral sample corpus.
CODALITH_SAMPLE_CORPUS_ID=sample-codebase
CODALITH_SAMPLE_VERSION=sample
CODALITH_SAMPLE_SOURCE_COMMIT=UNKNOWN
CODALITH_SAMPLE_DISPLAY_NAME=Sample Codebase
CODALITH_SAMPLE_DESCRIPTION=Small neutral source corpus for local Codalith development
CODALITH_SAMPLE_SOURCE_ROOT=fixtures/sample_corpus
CODALITH_SAMPLE_INDEXED_ROOT=fixtures/sample_corpus
CODALITH_SAMPLE_CODERAG_STORE_DIR=data/coderag/sample-codebase
CODALITH_SAMPLE_SEMANTIC_SCHEMA=sample_codebase
CODALITH_SAMPLE_CARD_ROOT=data/cards/sample-codebase
CODALITH_SAMPLE_SOURCE_PRIORS=configs/source_priors.json
CODALITH_SAMPLE_SEED_CARDS=configs/seed_cards.json
CODALITH_CORPUS_REGISTRY=configs/corpus_registry.json
CODALITH_SOURCE_POLICY=configs/source_policy.json

# Granted scopes. Leave empty to grant base capabilities plus every corpus
# access scope from corpus_registry.json (self-hosted default).
CODALITH_SCOPES=
CODALITH_HTTP_BEARER_TOKEN=
CODALITH_HTTP_IDENTITY_HEADER=

# Host and container paths.
CODALITH_REPO_ROOT=.
CODALITH_WORKSPACE_DIR=/workspace

# UE is eval-only. These are not used by the default MCP service.
CODALITH_EVAL_UE_VERSION=5.7.4
CODALITH_EVAL_UE_SOURCE_COMMIT=UNKNOWN
CODALITH_EVAL_UE_HOST_ROOT=E:/UnrealEngine_5.7
CODALITH_EVAL_UE_SOURCE_HOST_ROOT=E:/UnrealEngine_5.7/Engine/Source
CODALITH_EVAL_UE_PLUGINS_HOST_ROOT=E:/UnrealEngine_5.7/Engine/Plugins
CODALITH_EVAL_UE_SOURCE_ROOT=/srv/ue/5.7.4
CODALITH_EVAL_UE_INDEXED_ROOT=/srv/codalith/corpora/ue-5.7.4
CODALITH_EVAL_UE_CODERAG_STORE_DIR=/var/lib/codalith/coderag/ue-5.7.4
CODALITH_EVAL_UE_CARD_ROOT=data/cards/ue-5.7.4
CODALITH_EVAL_UE_SOURCE_PRIORS=eval/configs/ue_source_priors.json
CODALITH_EVAL_UE_SEED_CARDS=eval/configs/ue_seed_cards.json

# Optional host path for large OpenAI-compatible LanceDB stores.
# Leave empty to use the Docker named volume `coderag-openai-store`.
CODALITH_CODERAG_OPENAI_HOST_ROOT=
CODALITH_CODERAG_OPENAI_STORE_DIR=/var/lib/codalith/coderag/sample-codebase-openai
CODALITH_CODERAG_VOLUME_ROOT=/var/lib/codalith/coderag

# Runtime and Python package settings.
CODALITH_AUDIT_LOG=/workspace/data/audit/source_reads.jsonl
CODALITH_SEMANTIC_DSN=postgresql://codalith:codalith@postgres:5432/codalith
# Local non-Compose fallback only. CODALITH_SEMANTIC_DSN takes precedence when set.
CODALITH_SEMANTIC_DB=/workspace/data/semantic/codalith.sqlite
CODALITH_POSTGRES_DB=codalith
CODALITH_POSTGRES_USER=codalith
CODALITH_POSTGRES_PASSWORD=codalith
CODALITH_UV_ENV=/tmp/codalith-venv
CODALITH_PYPI_INDEX=https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple/
LANCE_INCLUDE_VECTOR_CENTROIDS=false

# Default CodeRAG provider used by local commands.
CODALITH_CODERAG_PROVIDER=fake
CODALITH_CODERAG_ALLOW_AUTO_CLONE=0
# Native CodeRAG toggle: 1 = use the pinned external/CodeRAG engine, empty = local fallback.
CODALITH_USE_NATIVE_CODERAG=
# Strict mode fails instead of falling back when native CodeRAG errors; progress logs indexing.
CODALITH_NATIVE_CODERAG_STRICT=
CODALITH_NATIVE_CODERAG_PROGRESS=
CODALITH_CODERAG_MAX_CHUNK_CHARS=2048
CODALITH_CODERAG_MAX_CHUNK_BYTES=
CODALITH_CODERAG_BATCH_CHUNKS=
CODALITH_CODERAG_BATCH_CONCURRENCY=
CODALITH_CODERAG_EMBED_MIN_BATCH_CHUNKS=
CODALITH_CODERAG_WORKERS=4

# OpenAI-compatible provider settings for optional CodeRAG acceptance.
OPENAI_BASE_URL=https://api.example.com/v1
OPENAI_API_KEY=replace-me
CODALITH_CODERAG_EMBEDDING_MODEL=Qwen3-Embedding-8B
CODALITH_CODERAG_EMBEDDING_BATCH_SIZE=32
CODALITH_CODERAG_OPENAI_TIMEOUT_SECONDS=120
CODALITH_CODERAG_OPENAI_RETRY_ATTEMPTS=3

# Optional HTTP MCP server settings.
CODALITH_HTTP_BIND=127.0.0.1
CODALITH_HTTP_HOST=0.0.0.0
CODALITH_HTTP_PORT=8765
CODALITH_HTTP_ENDPOINT=/mcp
CODALITH_HTTP_ALLOWED_ORIGINS=
# Set to 1 to log HTTP access lines and JSON-RPC request/response bodies to stderr.
CODALITH_HTTP_LOG=
# Truncate verbose body dumps after this many characters (default 16384).
CODALITH_HTTP_LOG_MAX_CHARS=16384


# Codalith local/deployment configuration.
# Copy this file to .env and change host paths and credentials per machine.

# Engine identity and access scope.
CODALITH_ENGINE_VERSION=5.7.4
CODALITH_ENGINE_SOURCE_COMMIT=UNKNOWN
# Client-facing corpus identity. The MCP server advertises these in its
# initialize instructions and resource names; keywords in corpus_registry.json.
CODALITH_ENGINE_DISPLAY_NAME=Unreal Engine
CODALITH_ENGINE_DESCRIPTION=Unreal Engine full source tree (C++, Build.cs, plugins, generated reflection code)
CODALITH_ENGINE_ACCESS_SCOPE=ue:5.7
CODALITH_ENGINE_SEMANTIC_SCHEMA=ue_5_7_4
CODALITH_SCOPES=source:read,index:status,cards:read,graph:read,ue:5.7
CODALITH_HTTP_BEARER_TOKEN=
CODALITH_HTTP_IDENTITY_HEADER=

# Host paths. These are the values most deployments need to change.
CODALITH_REPO_ROOT=.
CODALITH_ENGINE_HOST_ROOT=E:/UnrealEngine_5.7
CODALITH_ENGINE_SOURCE_HOST_ROOT=E:/UnrealEngine_5.7/Engine/Source
CODALITH_GAMEPLAY_ABILITIES_HOST_ROOT=E:/UnrealEngine_5.7/Engine/Plugins/Runtime/GameplayAbilities

# Container paths. Keep these stable unless your server policy requires different mount points.
CODALITH_WORKSPACE_DIR=/workspace
CODALITH_ENGINE_SOURCE_ROOT=/srv/ue/5.7.4
CODALITH_ENGINE_INDEXED_ROOT=/srv/codalith/corpora/ue-5.7.4
CODALITH_ENGINE_CARD_ROOT=/srv/codalith/cards/ue-5.7.4
CODALITH_CODERAG_STORE_DIR=/var/lib/codalith/coderag/ue-5.7.4
CODALITH_CODERAG_OPENAI_STORE_DIR=/var/lib/codalith/coderag/ue-5.7.4-openai-qwen3-embedding-8b
CODALITH_CODERAG_VOLUME_ROOT=/var/lib/codalith/coderag

# Optional project overlay corpus. Defaults resolve to the bundled ProjectA fixture.
CODALITH_PROJECT_ID=ProjectA
CODALITH_PROJECT_DISPLAY_NAME=Game project overlay
CODALITH_PROJECT_SOURCE_ROOT=fixtures/project_overlay/ProjectA
CODALITH_PROJECT_INDEXED_ROOT=fixtures/project_overlay/ProjectA
CODALITH_PROJECT_CODERAG_STORE_DIR=data/coderag/project-a
CODALITH_PROJECT_SEMANTIC_SCHEMA=project_a
CODALITH_PROJECT_CARD_ROOT=data/cards/project-a
CODALITH_PROJECT_ACCESS_SCOPE=project:ProjectA

# Optional generated/log/crash/build-output overlay. Add generated:read to CODALITH_SCOPES to query it.
CODALITH_GENERATED_SOURCE_ROOT=data/generated/ue-5.7.4
CODALITH_GENERATED_INDEXED_ROOT=data/generated/ue-5.7.4
CODALITH_GENERATED_CODERAG_STORE_DIR=data/coderag/generated-ue-5.7.4
CODALITH_GENERATED_SEMANTIC_SCHEMA=generated_ue_5_7_4
CODALITH_GENERATED_CARD_ROOT=data/cards/generated-ue-5.7.4
CODALITH_GENERATED_ACCESS_SCOPE=generated:read

# Optional host path for large OpenAI-compatible LanceDB stores.
# Leave empty to use the Docker named volume `coderag-openai-store`.
CODALITH_CODERAG_OPENAI_HOST_ROOT=

# Runtime and Python package settings.
CODALITH_AUDIT_LOG=/workspace/data/audit/source_reads.jsonl
CODALITH_SEMANTIC_DSN=postgresql://codalith:codalith@postgres:5432/codalith
# Local non-Compose fallback only. CODALITH_SEMANTIC_DSN takes precedence when set.
CODALITH_SEMANTIC_DB=/workspace/data/semantic/codalith.sqlite
CODALITH_POSTGRES_DB=codalith
CODALITH_POSTGRES_USER=codalith
CODALITH_POSTGRES_PASSWORD=codalith
CODALITH_UV_ENV=/tmp/codalith-venv
CODALITH_PYPI_INDEX=https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple/
LANCE_INCLUDE_VECTOR_CENTROIDS=false

# Default CodeRAG provider used by local commands.
CODALITH_CODERAG_PROVIDER=fake
CODALITH_CODERAG_ALLOW_AUTO_CLONE=0
# Native CodeRAG toggle: 1 = use the pinned external/CodeRAG engine, empty = local fallback.
CODALITH_USE_NATIVE_CODERAG=
# Strict mode fails instead of falling back when native CodeRAG errors; progress logs indexing.
CODALITH_NATIVE_CODERAG_STRICT=
CODALITH_NATIVE_CODERAG_PROGRESS=
# Set to 1 in ue_acceptance runs that require the semantic store to be pre-populated.
CODALITH_EXPECT_SEMANTIC_READY=
# Optional override for the source prior dataset (defaults to configs/source_priors.json).
CODALITH_SOURCE_PRIORS=
CODALITH_CODERAG_MAX_CHUNK_CHARS=2048
CODALITH_CODERAG_MAX_CHUNK_BYTES=
CODALITH_CODERAG_BATCH_CHUNKS=
CODALITH_CODERAG_BATCH_CONCURRENCY=
CODALITH_CODERAG_EMBED_MIN_BATCH_CHUNKS=
CODALITH_CODERAG_WORKERS=4

# OpenAI-compatible provider settings for mcp-http and coderag-openai-acceptance.
OPENAI_BASE_URL=https://api.example.com/v1
OPENAI_API_KEY=replace-me
CODALITH_CODERAG_EMBEDDING_MODEL=Qwen3-Embedding-8B
CODALITH_CODERAG_EMBEDDING_BATCH_SIZE=32
CODALITH_CODERAG_OPENAI_TIMEOUT_SECONDS=120
CODALITH_CODERAG_OPENAI_RETRY_ATTEMPTS=3

# Optional HTTP MCP server settings.
CODALITH_HTTP_BIND=127.0.0.1
CODALITH_HTTP_HOST=0.0.0.0
CODALITH_HTTP_PORT=8765
CODALITH_HTTP_ENDPOINT=/mcp
CODALITH_HTTP_ALLOWED_ORIGINS=
CODALITH_HTTP_LOG=

# Optional MCP client installer settings.
CODALITH_MCP_CLIENT=all
CODALITH_MCP_URL=http://127.0.0.1:8765/mcp
CODALITH_MCP_TOKEN=
CODALITH_MCP_NAME=codalith
CODALITH_MCP_SCOPE=user
CODALITH_MCP_CONFIG_PATH=

# Copy to .env for Docker Compose. Values remain local and are never committed.
CODALITH_DEFAULT_TARGET=sample
CODALITH_REGISTRY=/app/configs/registry.toml
CODALITH_SOURCE_POLICY=/app/configs/source-policy.toml

# Streamable HTTP is loopback-published by default.
CODALITH_HTTP_BIND=127.0.0.1
CODALITH_HTTP_HOST=0.0.0.0
CODALITH_HTTP_PORT=8765
CODALITH_HTTP_ENDPOINT=/mcp
CODALITH_HTTP_ALLOWED_ORIGINS=
CODALITH_HTTP_ALLOWED_HOSTS=
CODALITH_HTTP_MAX_REQUEST_BYTES=1048576

# OpenAI-compatible embedding endpoint. Required when querying or rebuilding
# a corpus configured with embedding_provider = "openai".
CODALITH_EMBEDDING_BASE_URL=
CODALITH_EMBEDDING_API_KEY=
LANCE_INCLUDE_VECTOR_CENTROIDS=false

# UE profile host mounts.
CODALITH_UE_SOURCE_HOST_DIR=./.local/ue-5.7.4
CODALITH_UE_INDEX_HOST_DIR=./.local/indexes/ue-5.7.4
CODALITH_UE_CODERAG_HOST_DIR=./.local/coderag/ue-5.7.4
CODALITH_UE_SOURCE_REVISION=5.7.4
CODALITH_UE_EMBEDDING_PROVIDER=openai
CODALITH_UE_EMBEDDING_MODEL=text-embedding-3-small

# UE Context Engine local/deployment configuration.
# Copy this file to .env and change host paths for each machine.

UE_CONTEXT_ENGINE_VERSION=5.7.4
UE_CONTEXT_ENGINE_SOURCE_COMMIT=UNKNOWN
UE_CONTEXT_ENGINE_ACCESS_SCOPE=ue:5.7
UE_CONTEXT_SCOPES=source:read,index:status,cards:read,graph:read,ue:5.7

# Host paths. These are the values most deployments need to change.
UE_CONTEXT_REPO_ROOT=.
UE_CONTEXT_ENGINE_HOST_ROOT=E:/UnrealEngine_5.7
UE_CONTEXT_ENGINE_SOURCE_HOST_ROOT=E:/UnrealEngine_5.7/Engine/Source
UE_CONTEXT_GAMEPLAY_ABILITIES_HOST_ROOT=E:/UnrealEngine_5.7/Engine/Plugins/Runtime/GameplayAbilities

# Container paths. Keep these stable unless your server policy requires different mount points.
UE_CONTEXT_WORKSPACE_DIR=/workspace
UE_CONTEXT_ENGINE_SOURCE_ROOT=/srv/ue/5.7.4
UE_CONTEXT_ENGINE_INDEXED_ROOT=/srv/ue-context/corpora/ue-5.7.4
UE_CONTEXT_ENGINE_CARD_ROOT=/srv/ue-context/cards/ue-5.7.4
UE_CONTEXT_CODERAG_STORE_DIR=/var/lib/ue-context/coderag/ue-5.7.4
UE_CONTEXT_CODERAG_OLLAMA_STORE_DIR=/var/lib/ue-context/coderag/ue-5.7.4-ollama-qwen3-embedding-0.6b
UE_CONTEXT_CODERAG_VOLUME_ROOT=/var/lib/ue-context/coderag

# Runtime and tool settings.
UE_CONTEXT_AUDIT_LOG=/workspace/data/audit/source_reads.jsonl
UE_CONTEXT_SEMANTIC_DB=/tmp/ue-context-semantic.sqlite
UE_CONTEXT_UV_ENV=/tmp/ue-context-venv
UE_CONTEXT_PYPI_INDEX=https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple/
CODERAG_PROVIDER=fake
CODERAG_INDEX_ALL_TEXT=1

# Optional Ollama/OpenAI-compatible embedding settings for the coderag-ollama-acceptance profile.
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_API_KEY=ollama
CODERAG_OPENAI_MODEL=qwen3-embedding:0.6b
CODERAG_OPENAI_BATCH=32
CODERAG_WORKERS=4
UE_CONTEXT_CODERAG_MAX_CHUNK_CHARS=2048

# Optional HTTP MCP server settings.
UE_CONTEXT_HTTP_HOST=127.0.0.1
UE_CONTEXT_HTTP_PORT=8765
UE_CONTEXT_HTTP_ENDPOINT=/mcp
UE_CONTEXT_HTTP_ALLOWED_ORIGINS=
